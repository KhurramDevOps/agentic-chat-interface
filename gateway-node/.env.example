NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gateway

# JWT
JWT_SECRET=replace-with-strong-access-token-secret
JWT_REFRESH_SECRET=legacy-unused-replace-if-needed

# Python service
PYTHON_BASE_URL=http://127.0.0.1:8000
PYTHON_API_URL=http://127.0.0.1:8000/api/v1/chat/completions
PYTHON_STREAM_URL=http://127.0.0.1:8000/api/v1/chat/stream
PYTHON_API_KEY=replace-with-service-api-key
