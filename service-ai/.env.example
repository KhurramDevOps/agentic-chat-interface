# ─────────────────────────────────────────────
# service-ai — Environment Configuration
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# Runtime
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── LLM Provider ──────────────────────────────
# Switch between providers by changing LLM_PROVIDER.
# Only the active provider's key and model are used.

# Active provider: gemini | groq
LLM_PROVIDER=gemini

# ── Gemini (Google) ───────────────────────────
LITELLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here   # https://aistudio.google.com/apikey

# ── Groq ──────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key-here       # https://console.groq.com/keys

# ── Memory ────────────────────────────────────
MEM0_API_KEY=your-mem0-api-key-here       # leave blank for local in-memory mode

# ── OpenAI SDK (unused — kept for compatibility)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=                          # optional: override for LiteLLM proxy

# ── Search ────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here   # https://app.tavily.com/

# ── Background task limits ────────────────────
MEDIA_TASK_TIMEOUT_SECONDS=300
MEDIA_TASK_MAX_QUEUE=50
